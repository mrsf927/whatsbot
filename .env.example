# =============================================================
# WhatsBot — Environment Variables
# Copie este arquivo para .env e preencha os valores
# =============================================================

# [OBRIGATÓRIO] API key do OpenRouter para o LLM
OPENROUTER_API_KEY=

# Modelo principal (padrão: openai/gpt-4o-mini)
WHATSBOT_MODEL=openai/gpt-4o-mini

# Modelo para transcrição de áudio (padrão: google/gemini-2.0-flash-001)
WHATSBOT_AUDIO_MODEL=google/gemini-2.0-flash-001

# Modelo para análise de imagens (padrão: google/gemini-2.0-flash-001)
WHATSBOT_IMAGE_MODEL=google/gemini-2.0-flash-001

# System prompt do bot (opcional)
WHATSBOT_SYSTEM_PROMPT=Você é um assistente útil e amigável. Responda de forma clara e concisa. Use português brasileiro.

# Porta do servidor web (padrão: 8080)
WHATSBOT_WEB_PORT=8080

# Porta interna do GOWA bridge (padrão: 64999)
WHATSBOT_GOWA_PORT=64999

# Habilitar resposta automática (true/false, padrão: false)
WHATSBOT_AUTO_REPLY=false

# Máximo de mensagens de contexto enviadas ao LLM (padrão: 10)
WHATSBOT_MAX_CONTEXT=10

# Delay em segundos para agrupar mensagens do mesmo contato (padrão: 3.0)
WHATSBOT_BATCH_DELAY=3.0
